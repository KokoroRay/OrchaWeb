# ORCHA E-commerce Platform - Environment Configuration

# API Configuration
# Replace with your actual AWS API Gateway endpoint after deployment
VITE_API_BASE_URL=https://your-api-id.execute-api.ap-southeast-1.amazonaws.com/prod

# AWS Cognito Configuration
# User Pool ID from AWS Cognito Console
VITE_COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx

# App Client ID from AWS Cognito Console  
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Domain (format: https://your-domain.auth.region.amazoncognito.com)
VITE_COGNITO_DOMAIN=https://your-domain.auth.ap-southeast-1.amazoncognito.com

# Redirect URI after OAuth login (use localhost for development)
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# Image Upload Service (Cloudinary)
# Get free account at https://cloudinary.com
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Payment Gateway (PayOS) - Optional
# Register at https://payos.vn
VITE_PAYOS_CLIENT_ID=your-payos-client-id
VITE_PAYOS_API_KEY=your-payos-api-key
VITE_PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Application Settings
VITE_APP_NAME=ORCHA
VITE_APP_VERSION=1.0.0
VITE_ENABLE_COD=true
VITE_ENABLE_PAYOS=true
